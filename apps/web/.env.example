# Copy to .env.local (or .env) and fill in real values. Do not commit secrets.

# Supabase Postgres connection string.
# Use the POOLER URL (port 6543, transaction mode) — required for serverless / route handlers.
# Find it: Supabase dashboard → Project Settings → Database → Connection string → "Transaction"
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres"

# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-me-with-64-bytes-of-hex"

# Session/cookie lifetime in seconds (7 days = 604800)
SESSION_MAX_AGE=604800
