# Copy to .env.local (or .env) and fill in real values. Do not commit secrets.

# Supabase Postgres connection string.
# Use the POOLER URL (port 6543, transaction mode) — required for serverless / route handlers.
# Find it: Supabase dashboard → Project Settings → Database → Connection string → "Transaction"
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres"

# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-me-with-64-bytes-of-hex"

# Session/cookie lifetime in seconds (7 days = 604800)
SESSION_MAX_AGE=604800

# Google Maps Platform key for GM Prospecting (server-side use).
# Enable: Places API (New) + Geocoding API. Restrict by HTTP referrer + API in prod.
# https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=

# Same Maps key (or a separate browser-restricted one) for the map widget +
# location autocomplete. Exposed to the client bundle via NEXT_PUBLIC_ prefix.
# In production, lock this key to your origin via HTTP referrer restrictions.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
